---
import { getCollection } from 'astro:content';
import { buildSlugIndex, resolveWikilink } from '../utils/slug-map';
import Layout from '../layouts/Layout.astro';

const allNotes = await getCollection('notes');
const { byPath, byName } = await buildSlugIndex();

const nodes = allNotes.map(n => ({
  id: n.id,
  name: n.data.title,
}));

const links: { source: string; target: string }[] = [];
allNotes.forEach(source => {
  const matches = source.body?.match(/\[\[(.*?)\]\]/g);
  if (matches) {
    matches.forEach(link => {
      const targetName = link.replace(/[\[\]]/g, '').split('|')[0];
      const targetId = resolveWikilink(targetName, byPath, byName, source.id);
      if (targetId) {
        links.push({ source: source.id, target: targetId });
      }
    });
  }
});

const graphData = { nodes, links };
---

<Layout title="全局图谱">
  <div style="display: flex; flex-direction: column; height: 100vh;">
    <header style="padding: 16px 24px; display: flex; align-items: center; gap: 16px;">
      <a href="/" style="color: #ccc;">← 返回</a>
      <h1 style="color: #fff; font-size: 18px; margin: 0;">Global Graph</h1>
    </header>
    <div id="global-graph" style="flex: 1;" data-graph={JSON.stringify(graphData)}></div>
  </div>
</Layout>

<script>
  import ForceGraph from 'force-graph';

  const el = document.getElementById('global-graph')!;
  const data = JSON.parse(el.dataset.graph || '{}');

  ForceGraph()(el)
    .graphData(data)
    .nodeId('id')
    .nodeLabel('name')
    .nodeColor(() => '#6ab0e6')
    .nodeVal(2)
    .nodeCanvasObject((node: any, ctx: CanvasRenderingContext2D, globalScale: number) => {
      const r = 4 / globalScale;
      // 画圆点
      ctx.beginPath();
      ctx.arc(node.x, node.y, r, 0, Math.PI * 2);
      ctx.fillStyle = '#6ab0e6';
      ctx.fill();
      // 画文字
      const fontSize = 12 / globalScale;
      ctx.font = `${fontSize}px Sans-Serif`;
      ctx.textAlign = 'center';
      ctx.textBaseline = 'top';
      ctx.fillStyle = '#cccccc';
      ctx.fillText(node.name, node.x, (node.y || 0) + r + 2 / globalScale);
    })
    .linkColor(() => 'rgba(136,136,136,0.3)')
    .linkWidth(1)
    .backgroundColor('#1e1e1e')
    .warmupTicks(50)
    .cooldownTicks(200)
    .onNodeClick((node: any) => {
      window.location.href = `/notes/${node.id}`;
    });
</script>
