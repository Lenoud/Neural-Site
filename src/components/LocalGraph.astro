---
interface Props {
  graphDataD1: {
    nodes: { id: string; name: string }[];
    links: { source: string; target: string }[];
  };
  graphDataD2: {
    nodes: { id: string; name: string }[];
    links: { source: string; target: string }[];
  };
  graphDataD3: {
    nodes: { id: string; name: string }[];
    links: { source: string; target: string }[];
  };
  currentId: string;
}
const { graphDataD1, graphDataD2, graphDataD3, currentId } = Astro.props;
const base = import.meta.env.BASE_URL;
---

<section class="graph-section">
  <div class="graph-header">
    <h4>交互图谱</h4>
    <div class="depth-control">
      <label for="graph-depth">深度</label>
      <input type="range" id="graph-depth" min="1" max="3" step="1" value="1" />
      <span class="depth-value">1</span>
    </div>
  </div>
  <div
    id="local-graph"
    data-graph-d1={JSON.stringify(graphDataD1)}
    data-graph-d2={JSON.stringify(graphDataD2)}
    data-graph-d3={JSON.stringify(graphDataD3)}
    data-current={currentId}
  ></div>
  <a href={`${base}graph`} class="expand-link">展开 →</a>
</section>

<style>
  .graph-section { margin-bottom: 24px; }
  .graph-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 4px;
  }
  .graph-header h4 { margin: 0; }
  .depth-control {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 12px;
    color: var(--text-muted);
  }
  .depth-control input[type="range"] {
    width: 60px;
    height: 4px;
    accent-color: #6ab0e6;
    cursor: pointer;
  }
  .depth-value {
    min-width: 14px;
    text-align: center;
    font-weight: bold;
    color: #6ab0e6;
  }
  #local-graph { width: 100%; height: 200px; border: 1px solid var(--border-color); border-radius: 6px; }
  .expand-link {
    display: inline-block;
    margin-top: 8px;
    color: var(--text-muted);
    font-size: 12px;
  }
</style>

<script>
  import ForceGraph from 'force-graph';

  document.querySelectorAll('#local-graph').forEach(container => {
    const el = container as HTMLElement;
    const dataD1 = JSON.parse(el.dataset.graphD1 || '{}');
    const dataD2 = JSON.parse(el.dataset.graphD2 || '{}');
    const dataD3 = JSON.parse(el.dataset.graphD3 || '{}');
    const currentId = el.dataset.current;
    const datasets = [null, dataD1, dataD2, dataD3];
    let hoverNodeId: string | null = null;

    const graph = ForceGraph()(el)
      .graphData(dataD1)
      .nodeId('id')
      .nodeLabel('name')
      .nodeColor((node: any) => node.id === currentId ? '#6ab0e6' : '#666666')
      .nodeVal((node: any) => node.id === currentId ? 3 : 1)
      .nodeCanvasObject((node: any, ctx: CanvasRenderingContext2D, globalScale: number) => {
        const r = (node.id === currentId ? 5 : 3) / globalScale;
        ctx.beginPath();
        ctx.arc(node.x, node.y, r, 0, Math.PI * 2);
        ctx.fillStyle = node.id === currentId ? '#6ab0e6' : '#666666';
        ctx.fill();
        const fontSize = 11 / globalScale;
        ctx.font = `${fontSize}px Sans-Serif`;
        ctx.textAlign = 'center';
        ctx.textBaseline = 'top';
        ctx.fillStyle = node.id === currentId ? '#ffffff' : '#aaaaaa';
        ctx.fillText(node.name, node.x, (node.y || 0) + r + 2 / globalScale);
      })
      .linkColor((link: any) => {
        if (!hoverNodeId) return 'rgba(136,136,136,0.3)';
        if (link.source.id === hoverNodeId || link.target.id === hoverNodeId) {
          return '#b388ff';
        }
        return 'rgba(136,136,136,0.06)';
      })
      .linkWidth((link: any) => {
        if (!hoverNodeId) return 1;
        if (link.source.id === hoverNodeId || link.target.id === hoverNodeId) {
          return 2;
        }
        return 0.5;
      })
      .backgroundColor('transparent')
      .width(el.offsetWidth)
      .height(200)
      .enableNodeDrag(false)
      .onNodeClick((node: any) => {
        if (node.id !== currentId) {
          window.location.href = `${import.meta.env.BASE_URL}notes/${node.id}`;
        }
      })
      .onNodeHover((node: any) => {
        hoverNodeId = node?.id || null;
        graph.linkColor(graph.linkColor());
      });

    const slider = el.parentElement?.querySelector('#graph-depth') as HTMLInputElement;
    const depthLabel = el.parentElement?.querySelector('.depth-value') as HTMLElement;
    if (slider && depthLabel) {
      slider.addEventListener('input', () => {
        const depth = parseInt(slider.value);
        depthLabel.textContent = slider.value;
        graph.graphData(datasets[depth]);
      });
    }
  });
</script>
