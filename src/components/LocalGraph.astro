---
interface Props {
  graphData: {
    nodes: { id: string; name: string }[];
    links: { source: string; target: string }[];
  };
  currentId: string;
}
const { graphData, currentId } = Astro.props;
const base = import.meta.env.BASE_URL;
---

<section class="graph-section">
  <h4>Interactive Graph</h4>
  <div id="local-graph" data-graph={JSON.stringify(graphData)} data-current={currentId}></div>
  <a href={`${base}graph`} class="expand-link">Expand →</a>
</section>

<style>
  .graph-section { margin-bottom: 24px; }
  #local-graph { width: 100%; height: 200px; border: 1px solid var(--border-color); border-radius: 6px; }
  .expand-link {
    display: inline-block;
    margin-top: 8px;
    color: var(--text-muted);
    font-size: 12px;
  }
</style>

<script>
  import ForceGraph from 'force-graph';

  document.querySelectorAll('#local-graph').forEach(container => {
    const el = container as HTMLElement;
    const data = JSON.parse(el.dataset.graph || '{}');
    const currentId = el.dataset.current;
    let hoverNodeId: string | null = null;

    const graph = ForceGraph()(el)
      .graphData(data)
      .nodeId('id')
      .nodeLabel('name')
      .nodeColor((node: any) => node.id === currentId ? '#6ab0e6' : '#666666')
      .nodeVal((node: any) => node.id === currentId ? 3 : 1)
      .nodeCanvasObject((node: any, ctx: CanvasRenderingContext2D, globalScale: number) => {
        const r = (node.id === currentId ? 5 : 3) / globalScale;
        ctx.beginPath();
        ctx.arc(node.x, node.y, r, 0, Math.PI * 2);
        ctx.fillStyle = node.id === currentId ? '#6ab0e6' : '#666666';
        ctx.fill();
        const fontSize = 11 / globalScale;
        ctx.font = `${fontSize}px Sans-Serif`;
        ctx.textAlign = 'center';
        ctx.textBaseline = 'top';
        ctx.fillStyle = node.id === currentId ? '#ffffff' : '#aaaaaa';
        ctx.fillText(node.name, node.x, (node.y || 0) + r + 2 / globalScale);
      })
      .linkColor((link: any) => {
        if (!hoverNodeId) return 'rgba(136,136,136,0.3)';
        if (link.source.id === hoverNodeId || link.target.id === hoverNodeId) {
          return '#b388ff';
        }
        return 'rgba(136,136,136,0.06)';
      })
      .linkWidth((link: any) => {
        if (!hoverNodeId) return 1;
        if (link.source.id === hoverNodeId || link.target.id === hoverNodeId) {
          return 2;
        }
        return 0.5;
      })
      .backgroundColor('transparent')
      .width(el.offsetWidth)
      .height(200)
      .enableNodeDrag(false)
      .onNodeClick((node: any) => {
        if (node.id !== currentId) {
          window.location.href = `${import.meta.env.BASE_URL}notes/${node.id}`;
        }
      })
      .onNodeHover((node: any) => {
        hoverNodeId = node?.id || null;
        graph.linkColor(graph.linkColor());
      });
  });
</script>
