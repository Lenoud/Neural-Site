---
import Sidebar from './Sidebar.astro';
import RightPanel from './RightPanel.astro';

interface Props {
  title: string;
  currentSlug?: string;
  headings?: { depth: number; slug: string; text: string }[];
  backlinks?: { slug: string; title: string }[];
  graphDataD1?: object;
  graphDataD2?: object;
  graphDataD3?: object;
  currentId?: string;
  metadata?: Record<string, string | undefined>;
}
const { title, currentSlug, headings = [], backlinks = [], graphDataD1, graphDataD2, graphDataD3, currentId, metadata } = Astro.props;
---
<div class="page-layout">
  <button class="mobile-toggle" id="mobile-toggle">☰</button>
  <aside class="sidebar" id="sidebar" data-current={currentSlug}>
    <Sidebar currentSlug={currentSlug} />
  </aside>
  <main class="content-area" data-pagefind-body>
    <slot />
  </main>
  <aside class="right-panel">
    <RightPanel
      headings={headings}
      backlinks={backlinks}
      graphDataD1={graphDataD1}
      graphDataD2={graphDataD2}
      graphDataD3={graphDataD3}
      currentId={currentId}
      metadata={metadata}
    />
  </aside>
</div>

<script>
  const toggle = document.getElementById('mobile-toggle');
  const sidebar = document.getElementById('sidebar');
  toggle?.addEventListener('click', () => sidebar?.classList.toggle('open'));
</script>
