---
interface NavItem {
  name: string;
  slug?: string;
  order?: number;
  children?: NavItem[];
}

interface Props {
  items: NavItem[];
  currentSlug?: string;
}

const { items, currentSlug = '' } = Astro.props;
const base = import.meta.env.BASE_URL;

function containsCurrent(item: NavItem): boolean {
  if (item.slug === currentSlug) return true;
  return item.children?.some(c => containsCurrent(c)) || false;
}

function renderTree(items: NavItem[], depth: number): string {
  return items.map(item => {
    if (item.children) {
      const isOpen = containsCurrent(item);
      return `<li>
        <details ${isOpen ? 'open' : ''} class="nav-folder" style="padding-left:${depth * 12}px">
          <summary class="nav-category">${item.name}</summary>
          <ul class="nav-list">${renderTree(item.children, depth + 1)}</ul>
        </details>
      </li>`;
    }
    const isActive = item.slug === currentSlug;
    return `<li style="padding-left:${(depth + 1) * 12}px">
      <a href="${base}notes/${item.slug}" class="nav-link${isActive ? ' active' : ''}">${item.name}</a>
    </li>`;
  }).join('');
}

const html = renderTree(items, 0);
---

<ul class="nav-list" set:html={html} />

<style is:global>
  .nav-list { list-style: none; }
  .nav-list .nav-list { list-style: none; }
  .nav-link {
    display: block;
    padding: 6px 12px;
    color: var(--text-secondary);
    border-radius: 4px;
    transition: background 0.15s;
    text-decoration: none;
  }
  .nav-link:hover { background: var(--bg-hover); color: var(--text-primary); }
  .nav-link.active { background: var(--bg-hover); color: var(--text-primary); }
  .nav-folder > summary {
    cursor: pointer;
    padding: 8px 12px;
    color: var(--text-muted);
    font-size: 13px;
    border-radius: 4px;
    transition: background 0.15s;
  }
  .nav-folder > summary:hover { background: var(--bg-hover); }
</style>
