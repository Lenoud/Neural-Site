---
const base = import.meta.env.BASE_URL;
---

<div id="search-dialog" class="search-overlay" style="display:none" data-base={base}>
  <div class="search-container">
    <input type="text" id="search-input" placeholder="搜索文档..." />
    <div id="search-results"></div>
  </div>
</div>

<style is:global>
  .search-overlay {
    position: fixed; inset: 0; z-index: 100;
    background: rgba(0,0,0,0.6);
    display: flex; justify-content: center; padding-top: 100px;
  }
  .search-container {
    width: 600px; max-height: 520px;
    background: var(--bg-sidebar); border-radius: 10px;
    overflow: hidden; border: 1px solid var(--border-color);
    display: flex; flex-direction: column;
  }
  #search-input {
    width: 100%; padding: 16px 20px;
    background: transparent; border: none; border-bottom: 1px solid var(--border-color);
    color: var(--text-primary); font-size: 16px; outline: none;
    flex-shrink: 0;
  }
  #search-results {
    padding: 16px; overflow-y: auto; flex: 1;
  }
  .search-card {
    display: block; padding: 14px 16px; margin-bottom: 12px;
    background: var(--bg-primary); border-radius: 8px;
    text-decoration: none; cursor: pointer;
    border: 1px solid var(--border-color);
    transition: border-color 0.15s, background 0.15s;
  }
  .search-card:hover { border-color: var(--accent, #6ab0e6); background: var(--bg-hover); }
  .search-card:last-child { margin-bottom: 0; }
  .search-title {
    display: block; font-weight: 600; color: var(--text-primary);
    font-size: 15px; margin-bottom: 8px;
  }
  .search-excerpt {
    display: block; font-size: 13px; color: var(--text-muted);
    line-height: 1.6;
    display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>

<script>
  let pagefindInstance: any = null;

  const dynamicImport = new Function('url', 'return import(url)') as (url: string) => Promise<any>;

  async function initSearch(basePath: string) {
    if (!pagefindInstance) {
      pagefindInstance = await dynamicImport(`${basePath}pagefind/pagefind.js`);
      await pagefindInstance.init({ baseUrl: basePath });
    }
    return pagefindInstance;
  }

  const overlay = document.getElementById('search-dialog')!;
  const basePath = overlay.dataset.base || '/';
  const input = document.getElementById('search-input') as HTMLInputElement;
  const results = document.getElementById('search-results')!;

  document.addEventListener('keydown', async (e) => {
    if ((e.metaKey || e.ctrlKey) && e.key === 'k') {
      e.preventDefault();
      overlay.style.display = 'flex';
      input.focus();
    }
    if (e.key === 'Escape') {
      overlay.style.display = 'none';
      input.value = '';
      results.innerHTML = '';
    }
  });

  overlay.addEventListener('click', (e) => {
    if (e.target === overlay) {
      overlay.style.display = 'none';
    }
  });

  input.addEventListener('input', async () => {
    const search = await initSearch(basePath);
    const query = input.value.trim();
    if (!query) { results.innerHTML = ''; return; }

    const response = await search.search(query);
    const html = await Promise.all(
      response.results.slice(0, 10).map(async (r: any) => {
        const data = await r.data();
        return `<a class="search-card" href="${data.url}"><span class="search-title">${data.meta?.title || data.url}</span><span class="search-excerpt">${data.excerpt || ''}</span></a>`;
      })
    );
    results.innerHTML = html.join('');
  });
</script>
