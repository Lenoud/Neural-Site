---
interface Props {
  backlinks: { slug: string; title: string }[];
}
const { backlinks } = Astro.props;
---

{backlinks.length > 0 && (
  <section>
    <h4>Links to This Page</h4>
    <ul class="backlink-list">
      {backlinks.map(bl => (
        <li><a href={`/notes/${bl.slug}`}>{bl.title}</a></li>
      ))}
    </ul>
  </section>
)}

<style>
  .backlink-list { list-style: none; }
  .backlink-list a {
    display: block;
    padding: 4px 0;
    color: var(--accent);
    font-size: 13px;
  }
</style>
